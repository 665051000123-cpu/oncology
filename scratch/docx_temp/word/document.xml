 w:after="0"/><w:ind w:firstLine="720"/><w:jc w:val="thaiDistribute"/><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK"/><w:sz w:val="32"/><w:szCs w:val="32"/></w:rPr></w:pPr><w:r w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t xml:space="preserve">เนื่องจากโรงพยาบาลมีความจำเป็นต้องเตรียมของพร้อมในหารดำเนินงานอย่างต่อเนื่อง </w:t></w:r><w:r w:rsidR="006E0152" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t>การบริหารจัดการข้อมูลผู้ป่วยในสถานพยาบาลหรือคลินิกมีความสำคัญอย่างยิ่ง การบันทึกข้อมูลด้วยกระดาษแบบดั้งเดิมมักประสบปัญหาเรื่องความล่าช้าในการค้นหา ความเสี่ยงต่อการสูญหาย และการเชื่อมโยงข้อมูลระหว่างแผนกที่เป็นไปได้ยาก</w:t></w:r><w:r w:rsidR="004026D9" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t>แผนกคอมพิวเตอร์ (</w:t></w:r><w:r w:rsidR="004026D9" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/></w:rPr><w:t>IT</w:t></w:r><w:r w:rsidR="004026D9" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t>)</w:t></w:r><w:r w:rsidR="00275884" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r w:rsidR="00275884" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t>จึงได้ออกแบบและพัฒนา</w:t></w:r><w:r w:rsidR="00560472" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t>ระบบคำนวณและตรวจสอบขนาดยาเคมีบำบัด ขึ้นมาใช้งาน</w:t></w:r><w:r w:rsidR="00E00FB1" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t>ภายในองค์กร เพื่อรองรับการปฏิบัติงานในภา</w:t></w:r><w:r w:rsidR="0035660F" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t>วะฉุกเฉิน โดยออกแบบให้มีความเหมาะสมกับลักษณะ</w:t></w:r><w:r w:rsidR="0051310E" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t>การใช้งานของแผนกเภส</w:t></w:r><w:r w:rsidR="00FB369A" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t>ัช</w:t></w:r><w:r w:rsidR="00E70668" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t>กรรม</w:t></w:r><w:r w:rsidR="00FB369A" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r w:rsidR="004C7BC8" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t xml:space="preserve">จัดทำมาช่วยจัดเก็บข้อมูลอย่างเป็นระบบ มีความปลอดภัยสูง และช่วยให้บุคลากรทางการแพทย์สามารถเข้าถึงข้อมูลที่จำเป็นได้อย่างรวดเร็ว แม่นยำ </w:t></w:r><w:r w:rsidR="004E717E" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t>เพื่อ</w:t></w:r><w:r w:rsidR="004C7BC8" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t>ส่งผลให้การบริการผู้ป่วยมีประสิทธิภาพสูงสุด</w:t></w:r><w:r w:rsidR="00323263" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t xml:space="preserve"> </w:t></w:r></w:p><w:p w14:paraId="78A741CA" w14:textId="790B0E23" w:rsidR="0060640F" w:rsidRPr="00921B72" w:rsidRDefault="004E717E" w:rsidP="00D3675F"><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr><w:spacing w:after="0"/><w:jc w:val="thaiDistribute"/><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK"/><w:sz w:val="32"/><w:szCs w:val="32"/></w:rPr></w:pPr><w:r w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t>วั</w:t></w:r><w:r w:rsidR="00D17502" w:rsidRPr="00921B72"><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:hAnsi="TH SarabunPSK" w:cs="TH SarabunPSK" w:hint="cs"/><w:sz w:val="32"/><w:szCs w:val="32"/><w:cs/></w:rPr><w:t>ตถุประสงค์</w:t></w:r></w:p><w:p w14:paraId="1D1AF1B8" w14:textId="1374888D" w:rsidR="0060640F" w:rsidRPr="00921B72" w:rsidRDefault="0060640F" w:rsidP="00D3675F"><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr><w:spacing w:after="0"/><w:jc w:val="thaiDistribute"/><w:rPr><w:rFonts w:ascii="TH SarabunPSK" w:h