+// ─────────────────────────────────────────────
+// 🧪 SOLVENTS API
+// ─────────────────────────────────────────────
+
+// GET all active solvents
+app.get('/api/solvents', async (req, res) => {
+    try {
+        const solvents = await Solvent.findAll({ where: { is_active: 1 }, order: [['solvent_name', 'ASC']] });
+        res.json({ success: true, solvents });
+    } catch (err) {
+        res.status(500).json({ success: false, message: err.message });
+    }
+});
+
+// POST add new solvent (with duplicate check)
+app.post('/api/solvents', async (req, res) => {
+    try {
+        const { solvent_name } = req.body;
+        if (!solvent_name || !solvent_name.trim()) {
+            return res.status(400).json({ success: false, message: 'กรุณาระบุชื่อตัวทำละลาย' });
+        }
+        const trimmed = solvent_name.trim();
+        const existing = await Solvent.findOne({
+            where: sequelize.where(sequelize.fn('LOWER', sequelize.col('solvent_name')), trimmed.toLowerCase())
+        });
+        if (existing) {
+            return res.status(409).json({ success: false, message: `มีตัวทำละลาย "${trimmed}" อยู่แล้วในระบบ`, duplicate: true });
+        }
+        const newSolvent = await Solvent.create({ solvent_name: trimmed, is_active: 1 });
+        res.json({ success: true, solvent: newSolvent });
+    } catch (err) {
+        if (err.name === 'SequelizeUniqueConstraintError') {
+            return res.status(409).json({ success: false, message: 'มีตัวทำละลายนี้อยู่แล้ว', duplicate: true });
+        }
+        res.status(500).json({ success: false, message: err.message });
+    }
+});
+
+// DELETE solvent (admin only)
+app.delete('/api/admin/solvents/:id', requireAdmin, async (req, res) => {
+    try {
+        await Solvent.destroy({ where: { solvent_id: req.params.id } });
+        res.json({ success: true });
+    } catch (err) {
+        res.status(500).json({ success: false, message: err.message });
+    }
+});
+
